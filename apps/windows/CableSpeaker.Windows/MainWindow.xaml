<Window x:Class="CableSpeaker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CableSpeaker"
        Height="520"
        Width="760"
        MinHeight="460"
        MinWidth="660"
        Background="#F6F7FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CableSpeaker"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#151821" />
            <TextBlock Text="Stream Windows audio to your Android phone through a USB cable."
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#4A5363" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,20">
            <Button x:Name="StartButton" Content="Start" Click="StartButton_Click" />
            <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False" />
            <Button x:Name="CheckPhoneButton" Content="Check Phone" Click="CheckPhoneButton_Click" />
            <Button x:Name="SetupTunnelButton" Content="Setup USB Tunnel" Click="SetupTunnelButton_Click" MinWidth="150" />
        </WrapPanel>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" Margin="0,0,10,0" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Windows audio" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBlock x:Name="AudioDeviceText" Margin="0,8,0,0" Foreground="#4A5363" />
                    <TextBlock Text="Level" Margin="0,16,0,4" Foreground="#4A5363" />
                    <ProgressBar x:Name="LevelMeter" Minimum="0" Maximum="1" Height="14" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" Margin="10,0,0,0" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Phone connection" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBlock x:Name="AdbStatusText" Margin="0,8,0,0" Foreground="#4A5363" />
                    <TextBlock x:Name="TunnelStatusText" Margin="0,8,0,0" Foreground="#4A5363" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Status" FontWeight="SemiBold" Foreground="#151821" />
                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="#FAFBFE"
                         Foreground="#252B36"
                         FontFamily="Consolas"
                         FontSize="13"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   Margin="0,14,0,0"
                   Foreground="#667085"
                   Text="Tip: keep the phone app open, press Connect there, then play audio on Windows." />
    </Grid>
</Window>

