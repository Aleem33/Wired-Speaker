<Window x:Class="CableSpeaker.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CableSpeaker"
        Height="720"
        Width="860"
        MinHeight="640"
        MinWidth="760"
        Background="#F6F7FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="CableSpeaker"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#151821" />
            <TextBlock Text="Use your Android phone as a USB laptop speaker and microphone."
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#4A5363" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,18">
            <Button x:Name="CheckPhoneButton" Content="Check Phone" Click="CheckPhoneButton_Click" />
            <Button x:Name="SetupTunnelButton" Content="Setup USB Tunnels" Click="SetupTunnelButton_Click" MinWidth="160" />
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" Margin="0,0,10,16" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Laptop Speaker To Phone" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBlock x:Name="AudioDeviceText" Margin="0,8,0,0" Foreground="#4A5363" TextWrapping="Wrap" />
                    <TextBlock Text="Laptop audio level" Margin="0,16,0,4" Foreground="#4A5363" />
                    <ProgressBar x:Name="LevelMeter" Minimum="0" Maximum="1" Height="14" />
                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="StartButton" Content="Start Speaker" Click="StartButton_Click" MinWidth="120" />
                        <Button x:Name="StopButton" Content="Stop Speaker" Click="StopButton_Click" IsEnabled="False" MinWidth="120" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" Margin="10,0,0,16" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Phone Mic To PC" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBlock Text="Output phone mic into this Windows playback device." Margin="0,8,0,4" Foreground="#4A5363" TextWrapping="Wrap" />
                    <ComboBox x:Name="MicOutputComboBox" SelectionChanged="MicOutputComboBox_SelectionChanged" MinHeight="30" />
                    <TextBlock x:Name="VbCableStatusText" Margin="0,8,0,0" Foreground="#4A5363" TextWrapping="Wrap" />
                    <TextBlock Text="Phone mic level" Margin="0,16,0,4" Foreground="#4A5363" />
                    <ProgressBar x:Name="MicLevelMeter" Minimum="0" Maximum="1" Height="14" />
                    <TextBlock x:Name="MicStatsText" Margin="0,8,0,0" Foreground="#4A5363" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="StartMicButton" Content="Start Mic Receiver" Click="StartMicButton_Click" MinWidth="140" />
                        <Button x:Name="StopMicButton" Content="Stop Mic Receiver" Click="StopMicButton_Click" IsEnabled="False" MinWidth="140" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" Margin="0,0,0,16" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="USB / ADB" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBlock x:Name="AdbStatusText" Margin="0,8,0,0" Foreground="#4A5363" />
                    <TextBlock x:Name="TunnelStatusText" Margin="0,8,0,0" Foreground="#4A5363" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="White" BorderBrush="#D9DEE8" BorderThickness="1" Padding="16" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Status" FontWeight="SemiBold" Foreground="#151821" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="#FAFBFE"
                             Foreground="#252B36"
                             FontFamily="Consolas"
                             FontSize="13"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,14,0,0"
                   Foreground="#667085"
                   TextWrapping="Wrap"
                   Text="For mic use in Discord/Zoom, select CABLE Output as the microphone after CableSpeaker sends phone mic audio to CABLE Input." />
    </Grid>
</Window>
